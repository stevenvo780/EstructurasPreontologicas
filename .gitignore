# Node modules y caches NPM (subproyecto ST)
08-consistencia-st/node_modules/
08-consistencia-st/.npm/
08-consistencia-st/npm-debug.log*

# Entorno virtual Python (corpus EDI)
09-simulaciones-edi/.venv/
09-simulaciones-edi/**/__pycache__/
09-simulaciones-edi/**/*.pyc
09-simulaciones-edi/**/*.pyo

# Cache de datos descargados (se regeneran ejecutando los casos)
09-simulaciones-edi/data_cache/
09-simulaciones-edi/**/data/*.csv
09-simulaciones-edi/**/data/*.json
09-simulaciones-edi/**/data_cache/

# Outputs antiguos no canónicos (los canónicos están versionados)
09-simulaciones-edi/**/outputs/*.tmp
09-simulaciones-edi/**/outputs/_old/

# Archivos del sistema
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# Logs y reports temporales
*.log
*.tmp
*.bak

# Bibliografía (libros de terceros con copyright; no versionados)
07-bibliografia/*.pdf
07-bibliografia/*.PDF


# React build artifacts
web_react/node_modules/
web_react/.vite/
# dist/ se commitea para que Vercel/FastAPI sirvan los assets compilados
