{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/api/index.py" },
    { "src": "/visualizations/(.*)", "dest": "/api/index.py" },
    { "src": "/sim_files/(.*)", "dest": "/api/index.py" },
    { "src": "/repo_files/(.*)", "dest": "/api/index.py" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/healthz", "dest": "/api/index.py" },
    { "src": "/casos/(.*)", "dest": "/api/index.py" },
    { "src": "/capitulos/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
