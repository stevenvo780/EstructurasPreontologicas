{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/healthz", "destination": "/api/index.py" },
    { "source": "/visualizations/:path*", "destination": "/api/index.py" },
    { "source": "/sim_files/:path*", "destination": "/api/index.py" },
    { "source": "/repo_files/:path*", "destination": "/api/index.py" },
    { "source": "/legacy_static/:path*", "destination": "/api/index.py" },
    { "source": "/legacy/:path*", "destination": "/api/index.py" },
    { "source": "/legacy", "destination": "/api/index.py" },
    { "source": "/", "destination": "/index.html" },
    {
      "source": "/((?!api|healthz|visualizations|sim_files|repo_files|legacy|assets|favicon|robots|.*\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot|map)$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "cache-control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
