{
  "version": 2,
  "buildCommand": "echo 'using prebuilt web_react/dist'",
  "outputDirectory": "web_react/dist",
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/healthz", "destination": "/api/index.py" },
    { "source": "/visualizations/(.*)", "destination": "/api/index.py" },
    { "source": "/sim_files/(.*)", "destination": "/api/index.py" },
    { "source": "/repo_files/(.*)", "destination": "/api/index.py" },
    { "source": "/legacy_static/(.*)", "destination": "/api/index.py" },
    { "source": "/legacy/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api|healthz|visualizations|sim_files|repo_files|legacy|assets|favicon|robots).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "cache-control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
