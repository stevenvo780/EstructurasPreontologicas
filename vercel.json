{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "web_react/dist/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "web_react/dist/assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/web_react/dist/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/healthz", "dest": "/api/index.py" },
    { "src": "/visualizations/(.*)", "dest": "/api/index.py" },
    { "src": "/sim_files/(.*)", "dest": "/api/index.py" },
    { "src": "/repo_files/(.*)", "dest": "/api/index.py" },
    { "src": "/legacy_static/(.*)", "dest": "/api/index.py" },
    { "src": "/legacy/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/web_react/dist/index.html" }
  ]
}
