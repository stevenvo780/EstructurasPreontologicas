{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 harness/cli.py:*)",
      "Bash(python3 harness/verifiers/*:*)",
      "Bash(python3 harness/lib/*:*)",
      "Bash(python3 harness/orchestrator.py:*)",
      "Bash(python3 09-simulaciones-edi/*:*)",
      "Bash(python3 TesisFinal/build.py:*)",
      "Bash(./tesis *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(cat harness/state.json)",
      "Bash(cat harness/config.yaml)",
      "Bash(cat harness/reports/*)",
      "Bash(jq *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add harness/*)",
      "Bash(git add .claude/*)",
      "Bash(pdftotext *)"
    ],
    "deny": [
      "Edit(09-simulaciones-edi/**/outputs/metrics.json)",
      "Write(09-simulaciones-edi/**/outputs/metrics.json)",
      "Edit(TesisFinal/Tesis.md)",
      "Write(TesisFinal/Tesis.md)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session_start_load_state.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/user_prompt_conflict_check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block_metrics_edit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block_tesis_md_edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block_destructive_git.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/protect_main_push.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post_validate_check_drift.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/checkpoint_state.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/continuous_dispatch_subagent_result.sh"
          }
        ]
      }
    ]
  }
}
